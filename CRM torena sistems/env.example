# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://crm_user:password@localhost:5432/crm"

# ── Server ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── JWT Auth ──────────────────────────────────────────────
JWT_SECRET="change-this-to-random-64-char-string"
JWT_EXPIRES_IN="7d"

# ── MinIO / S3 (хранилище записей звонков) ───────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="crm-recordings"

# ── Twilio (телефония) ────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_PHONE_NUMBER="+1234567890"

# ── Telegram Bot ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN="123456789:AAxxxxx"

# ── WhatsApp Business API ─────────────────────────────────
WHATSAPP_TOKEN="EAAxxxxxxx"
WHATSAPP_PHONE_ID="123456789"

# ── OpenAI (Whisper для транскрибации) ───────────────────
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxx"

# ── Production ────────────────────────────────────────────
BASE_URL="https://89.125.72.180"
